# Database Configuration
# Use SQLite for quick local development (default)
DATABASE_URL=sqlite+aiosqlite:///./distracted_driving.db
SYNC_DATABASE_URL=sqlite:///./distracted_driving.db

# Uncomment below to connect to PostgreSQL running in Docker (via port 6432)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:6432/distracted_driving_db
# SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:6432/distracted_driving_db

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_NAME=Distracted Driving Platform API
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4000,http://127.0.0.1:4000

# ── LLM Providers (set at least one) ─────────────────────────────────────────
# Gemini Flash — free tier available: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GPT-4o-mini fallback: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek fallback: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── ElevenLabs TTS ────────────────────────────────────────────────────────────
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Override voice IDs (leave blank to use defaults)
ELEVENLABS_PASSENGER_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_INSTRUCTOR_VOICE_ID=onwK4e9ZLuTAKqWW03F9
ELEVENLABS_AUTHORITY_VOICE_ID=pNInz6obpgDQGcFmaJgB

# PostgreSQL (for docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=distracted_driving_db
